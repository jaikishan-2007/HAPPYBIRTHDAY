<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Happy Birthday Amma 🎂</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0d0117;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }

    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-14px)} }
    @keyframes sparkle { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.2;transform:scale(0.4)} }
    @keyframes confetti-fall {
      0%{transform:translateY(-30px) rotate(0deg);opacity:1}
      100%{transform:translateY(110vh) rotate(720deg);opacity:0}
    }
    @keyframes flame { 0%,100%{transform:scaleY(1) scaleX(1)} 50%{transform:scaleY(1.18) scaleX(0.82)} }
    @keyframes pulse-glow {
      0%,100%{text-shadow:0 0 20px #f9a8d4,0 0 40px #f472b6}
      50%{text-shadow:0 0 40px #f9a8d4,0 0 80px #f472b6,0 0 120px #ec4899}
    }
    @keyframes fadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

    .scene {
      width: min(96vw, 560px);
      min-height: 600px;
      background: linear-gradient(160deg, #1a0533 0%, #2d0f4e 40%, #1a0533 100%);
      border-radius: 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.5rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 60px rgba(168,85,247,0.3), 0 0 120px rgba(236,72,153,0.15);
    }

    .stars { position:absolute;inset:0;pointer-events:none;z-index:0; }
    .star { position:absolute;background:#fff;border-radius:50%; }

    .confetti-piece {
      position:fixed;top:-30px;width:10px;height:10px;border-radius:2px;
      animation: confetti-fall linear infinite;
      pointer-events:none;
      z-index:999;
    }

    .title-main {
      font-size: clamp(36px, 8vw, 60px);
      font-weight: 600;
      color: #fce7f3;
      text-align: center;
      letter-spacing: 2px;
      animation: pulse-glow 2.5s ease-in-out infinite, fadeIn 0.8s ease forwards;
      z-index: 2;
      margin-bottom: 0.1rem;
      line-height: 1.1;
    }
    .title-name {
      font-size: clamp(52px, 11vw, 88px);
      font-weight: 700;
      color: #f9a8d4;
      text-align: center;
      animation: pulse-glow 2.5s ease-in-out infinite 0.3s, fadeIn 0.8s 0.2s ease both;
      z-index: 2;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .subtitle {
      font-size: clamp(13px, 2.5vw, 17px);
      color: #d8b4fe;
      text-align: center;
      letter-spacing: 5px;
      text-transform: uppercase;
      z-index: 2;
      margin-bottom: 2rem;
      opacity: 0.8;
      animation: fadeIn 0.8s 0.5s ease both;
    }

    .cake-wrap {
      animation: float 3s ease-in-out infinite;
      z-index: 2;
      margin-bottom: 1.8rem;
      animation-delay: 0.5s;
    }

    .msg {
      color: #fce7f3;
      font-size: clamp(15px, 2.5vw, 18px);
      text-align: center;
      max-width: 380px;
      line-height: 1.9;
      z-index: 2;
      opacity: 0.9;
      font-style: italic;
      animation: fadeIn 0.8s 0.8s ease both;
    }

    .hearts {
      display:flex;gap:14px;margin-top:1.4rem;z-index:2;
      animation: fadeIn 0.8s 1s ease both;
    }
    .heart { font-size:24px;animation:sparkle 1.6s ease-in-out infinite; }
    .heart:nth-child(2){animation-delay:0.3s}
    .heart:nth-child(3){animation-delay:0.6s}
    .heart:nth-child(4){animation-delay:0.9s}
    .heart:nth-child(5){animation-delay:1.2s}

    .footer {
      position: absolute;
      bottom: 14px;
      font-size: 12px;
      color: rgba(216,180,254,0.4);
      letter-spacing: 2px;
      text-transform: uppercase;
    }
  </style>
</head>
<body>

<div class="scene" id="scene">
  <div class="stars" id="stars"></div>

  <div class="title-main">Happy Birthday</div>
  <div class="title-name">Amma</div>
  <div class="subtitle">with all my love</div>

  <div class="cake-wrap">
    <svg width="180" height="200" viewBox="0 0 160 180" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="80" cy="160" rx="72" ry="10" fill="#7c3aed" opacity="0.35"/>
      <rect x="14" y="110" width="132" height="48" rx="10" fill="#db2777"/>
      <rect x="14" y="110" width="132" height="14" rx="6" fill="#ec4899"/>
      <rect x="26" y="70" width="108" height="44" rx="8" fill="#9333ea"/>
      <rect x="26" y="70" width="108" height="12" rx="5" fill="#a855f7"/>
      <rect x="42" y="38" width="76" height="36" rx="7" fill="#7c3aed"/>
      <rect x="42" y="38" width="76" height="11" rx="4" fill="#8b5cf6"/>
      <path d="M14 124 Q25 136 36 122 Q47 136 58 122 Q69 136 80 122 Q91 136 102 122 Q113 136 124 122 Q135 136 146 122" fill="none" stroke="#fce7f3" stroke-width="5" stroke-linecap="round"/>
      <path d="M26 82 Q35 93 44 82 Q53 93 62 82 Q71 93 80 82 Q89 93 98 82 Q107 93 116 82 Q125 93 134 82" fill="none" stroke="#e9d5ff" stroke-width="4" stroke-linecap="round"/>
      <circle cx="44" cy="136" r="5" fill="#fbbf24"/>
      <circle cx="80" cy="140" r="5" fill="#34d399"/>
      <circle cx="116" cy="136" r="5" fill="#f87171"/>
      <circle cx="62" cy="96" r="4" fill="#fbbf24"/>
      <circle cx="98" cy="96" r="4" fill="#f87171"/>
      <rect x="60" y="22" width="8" height="20" rx="3" fill="#fbbf24"/>
      <rect x="76" y="16" width="8" height="26" rx="3" fill="#f472b6"/>
      <rect x="92" y="22" width="8" height="20" rx="3" fill="#34d399"/>
      <ellipse cx="64" cy="20" rx="5" ry="7" fill="#fef08a" style="animation:flame 0.8s ease-in-out infinite;transform-origin:64px 24px"/>
      <ellipse cx="80" cy="14" rx="5" ry="7" fill="#fbbf24" style="animation:flame 0.8s ease-in-out infinite 0.2s;transform-origin:80px 18px"/>
      <ellipse cx="96" cy="20" rx="5" ry="7" fill="#fb923c" style="animation:flame 0.8s ease-in-out infinite 0.4s;transform-origin:96px 24px"/>
      <ellipse cx="64" cy="21" rx="2.5" ry="3.5" fill="#fff" opacity="0.7" style="animation:flame 0.8s ease-in-out infinite"/>
      <ellipse cx="80" cy="15" rx="2.5" ry="3.5" fill="#fff" opacity="0.7" style="animation:flame 0.8s ease-in-out infinite 0.2s"/>
      <ellipse cx="96" cy="21" rx="2.5" ry="3.5" fill="#fff" opacity="0.7" style="animation:flame 0.8s ease-in-out infinite 0.4s"/>
    </svg>
  </div>

  <p class="msg">
    your love, warmth, and grace<br>
    are the greatest gifts in my life. 🌸
  </p>

  <div class="hearts">
    <span class="heart">💖</span>
    <span class="heart">🌸</span>
    <span class="heart">✨</span>
    <span class="heart">🌸</span>
    <span class="heart">💖</span>
  </div>

  <div class="footer">♥ always &amp; forever ♥</div>
</div>

<script>
  const scene = document.getElementById('scene');
  const starsEl = document.getElementById('stars');

  for (let i = 0; i < 70; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const sz = Math.random() * 3 + 0.5;
    s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;opacity:${Math.random()*0.6+0.2};animation:sparkle ${1.5+Math.random()*2.5}s ease-in-out infinite;animation-delay:${Math.random()*4}s`;
    starsEl.appendChild(s);
  }

  const colors = ['#f472b6','#a78bfa','#fbbf24','#34d399','#fb923c','#e879f9','#38bdf8','#fff'];
  const shapes = ['border-radius:2px','border-radius:50%','transform:rotate(45deg)'];
  for (let i = 0; i < 40; i++) {
    const c = document.createElement('div');
    c.className = 'confetti-piece';
    const color = colors[Math.floor(Math.random() * colors.length)];
    const shape = shapes[Math.floor(Math.random() * shapes.length)];
    const dur = 3.5 + Math.random() * 5;
    const delay = Math.random() * 8;
    const size = 6 + Math.random() * 9;
    c.style.cssText = `left:${Math.random()*100}vw;background:${color};width:${size}px;height:${size}px;${shape};animation-duration:${dur}s;animation-delay:${delay}s`;
    document.body.appendChild(c);
  }
</script>
</body>
</html>
